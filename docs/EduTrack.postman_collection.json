{
  "info": {
    "name": "EduTrack API",
    "description": "Complete API test collection for EduTrack backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login - Success",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login/admin",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@edutrack.com\",\n  \"password\": \"Admin@123\"\n}" }
          }
        },
        {
          "name": "Admin Login - Wrong Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login/admin",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@edutrack.com\",\n  \"password\": \"wrongpass\"\n}" }
          }
        },
        {
          "name": "Student Login - Success",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login/student",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"student@test.com\",\n  \"password\": \"Test@123\"\n}" }
          }
        },
        {
          "name": "Teacher Login - Success",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login/teacher",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"teacher@test.com\",\n  \"password\": \"Test@123\"\n}" }
          }
        },
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register/student",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"newstudent@test.com\",\n  \"password\": \"Test@123\",\n  \"department\": \"Computer Science and Engineering\",\n  \"year\": \"1st Year\",\n  \"semester\": \"Sem 1\",\n  \"phone\": \"9876543210\",\n  \"usn\": \"1VT25CS001\"\n}" }
          }
        },
        {
          "name": "Change Admin Password - Success",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/change-password/admin",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": 1,\n  \"currentPassword\": \"Admin@123\",\n  \"newPassword\": \"NewPass@123\"\n}" }
          }
        },
        {
          "name": "Change Admin Password - Wrong Current",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/change-password/admin",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": 1,\n  \"currentPassword\": \"wrongpass\",\n  \"newPassword\": \"NewPass@123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "OTP",
      "item": [
        {
          "name": "Send OTP - Valid Student Email",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/otp/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"student@test.com\",\n  \"role\": \"student\"\n}" }
          }
        },
        {
          "name": "Send OTP - Email Not Found",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/otp/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ghost@nowhere.com\",\n  \"role\": \"student\"\n}" }
          }
        },
        {
          "name": "Send OTP - Wrong Role",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/otp/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@edutrack.com\",\n  \"role\": \"teacher\"\n}" }
          }
        },
        {
          "name": "Verify OTP - Invalid",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/otp/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"student@test.com\",\n  \"otp\": \"000000\"\n}" }
          }
        }
      ]
    },
